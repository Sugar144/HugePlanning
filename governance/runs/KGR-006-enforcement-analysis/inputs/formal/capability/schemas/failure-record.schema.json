{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hugeplanning.local/governance/schemas/0.1.0/failure-record.schema.json",
  "title": "HugePlanning Failure and Lesson Record",
  "type": "object",
  "additionalProperties": false,
  "required": ["failure_record"],
  "$defs": {
    "classification": {"enum": ["FAILURE", "NEAR_MISS", "AMBIGUITY", "PROCESS_DEFECT", "TOOLING_GAP", "COST_WASTE", "OWNER_CORRECTION"]},
    "severity": {"enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW", "OBSERVATION"]},
    "status": {"enum": ["OPEN", "CONTAINED", "CORRECTED", "VALIDATED", "ACCEPTED_RISK"]},
    "system_change": {"enum": ["SCRIPT", "VALIDATION", "SCHEMA", "TEST", "PROTOCOL", "AGENTS_INSTRUCTION", "SKILL", "MODEL_ROUTING", "WORKFLOW_PATTERN", "DOCUMENTATION"]},
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "locator", "anchor", "sha256", "availability", "note"],
      "properties": {
        "type": {"enum": ["REPOSITORY_PATH", "COMMIT", "RUN_ARTIFACT", "DECISION", "VALIDATION_RECORD", "OWNER_STATEMENT", "EXTERNAL"]},
        "locator": {"type": "string", "minLength": 1},
        "anchor": {"type": ["string", "null"]},
        "sha256": {"oneOf": [{"type": "null"}, {"type": "string", "pattern": "^[0-9a-f]{64}$"}]},
        "availability": {"enum": ["PRESERVED", "NOT_PRESERVED"]},
        "note": {"type": "string"}
      }
    },
    "subfinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "description", "evidence_refs"],
      "properties": {
        "title": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1},
        "evidence_refs": {"type": "array", "items": {"$ref": "#/$defs/evidence"}}
      }
    }
  },
  "properties": {
    "failure_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "id", "date", "recorded_on", "title", "context", "primary_classification", "classification", "severity", "status", "expected_behavior", "observed_behavior", "impact", "detection_method", "root_cause", "response", "learning", "metrics", "evidence_refs", "related_records", "subfindings", "owner_decision_required", "accepted_risk", "validation"],
      "properties": {
        "schema_version": {"const": "0.1.0"},
        "id": {"type": "string", "pattern": "^HP-FAIL-[0-9]{3}$"},
        "date": {"type": "string", "format": "date"},
        "recorded_on": {"type": "string", "format": "date"},
        "title": {"type": "string", "minLength": 1},
        "context": {
          "type": "object", "additionalProperties": false,
          "required": ["phase", "run", "component", "branch", "commit", "environment"],
          "properties": {
            "phase": {"type": "string", "minLength": 1}, "run": {"type": ["string", "null"]}, "component": {"type": "string", "minLength": 1}, "branch": {"type": "string", "minLength": 1}, "commit": {"oneOf": [{"type": "null"}, {"type": "string", "pattern": "^[0-9a-f]{40}$"}]}, "environment": {"type": ["string", "null"]}
          }
        },
        "primary_classification": {"$ref": "#/$defs/classification"},
        "classification": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/classification"}},
        "severity": {"$ref": "#/$defs/severity"},
        "status": {"$ref": "#/$defs/status"},
        "expected_behavior": {"type": "string", "minLength": 1},
        "observed_behavior": {"type": "string", "minLength": 1},
        "impact": {"type": "string", "minLength": 1},
        "detection_method": {"type": "string", "minLength": 1},
        "root_cause": {
          "type": "object", "additionalProperties": false, "required": ["immediate", "systemic", "contributing_factors"],
          "properties": {"immediate": {"type": "string", "minLength": 1}, "systemic": {"type": "string", "minLength": 1}, "contributing_factors": {"type": "array", "items": {"type": "string", "minLength": 1}}}
        },
        "response": {
          "type": "object", "additionalProperties": false, "required": ["containment", "correction", "prevention", "accountable_owner", "validation_required"],
          "properties": {"containment": {"type": "string", "minLength": 1}, "correction": {"type": "string", "minLength": 1}, "prevention": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}, "accountable_owner": {"type": "string", "minLength": 1}, "validation_required": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}}
        },
        "learning": {
          "type": "object", "additionalProperties": false, "required": ["reusable_lesson", "candidate_system_changes", "applicable_future_phases"],
          "properties": {"reusable_lesson": {"type": "string", "minLength": 1, "pattern": "^[^\\n\\r]+$"}, "candidate_system_changes": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/system_change"}}, "applicable_future_phases": {"type": "array", "items": {"type": "string", "minLength": 1}}}
        },
        "metrics": {
          "type": "object", "additionalProperties": false,
          "required": ["exact_token_usage", "model_runs", "model_and_reasoning", "human_time_minutes", "correction_cycles", "deterministic_rework_count", "package_rebuild_count", "measurement_quality", "basis"],
          "properties": {
            "exact_token_usage": {"type": ["integer", "null"], "minimum": 0}, "model_runs": {"type": ["integer", "null"], "minimum": 0},
            "model_and_reasoning": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["model", "reasoning", "runs"], "properties": {"model": {"type": "string", "minLength": 1}, "reasoning": {"type": "string", "minLength": 1}, "runs": {"type": ["integer", "null"], "minimum": 0}}}},
            "human_time_minutes": {"type": ["integer", "null"], "minimum": 0}, "correction_cycles": {"type": ["integer", "null"], "minimum": 0}, "deterministic_rework_count": {"type": ["integer", "null"], "minimum": 0}, "package_rebuild_count": {"type": ["integer", "null"], "minimum": 0},
            "measurement_quality": {"enum": ["EXACT", "ESTIMATED", "PARTIAL", "UNAVAILABLE"]}, "basis": {"type": "string", "minLength": 1}
          }
        },
        "evidence_refs": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/evidence"}},
        "related_records": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^HP-FAIL-[0-9]{3}$"}},
        "subfindings": {"type": "array", "items": {"$ref": "#/$defs/subfinding"}},
        "owner_decision_required": {"type": "boolean"},
        "accepted_risk": {"oneOf": [{"type": "null"}, {"type": "object", "additionalProperties": false, "required": ["owner_decision_ref", "scope", "rationale", "residual_impact", "review_on", "no_review_date_rationale", "reopening_triggers", "mandatory_controls"], "properties": {"owner_decision_ref": {"type": "string", "minLength": 1}, "scope": {"type": "string", "minLength": 1}, "rationale": {"type": "string", "minLength": 1}, "residual_impact": {"type": "string", "minLength": 1}, "review_on": {"type": ["string", "null"], "format": "date"}, "no_review_date_rationale": {"type": ["string", "null"]}, "reopening_triggers": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}, "mandatory_controls": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}}}]},
        "validation": {"type": "object", "additionalProperties": false, "required": ["validated_by", "validated_on", "validation_refs"], "properties": {"validated_by": {"type": ["string", "null"]}, "validated_on": {"type": ["string", "null"], "format": "date"}, "validation_refs": {"type": "array", "items": {"type": "string", "minLength": 1}}}}
      }
    }
  }
}
