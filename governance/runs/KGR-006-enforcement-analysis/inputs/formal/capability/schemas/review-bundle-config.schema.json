{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hugeplanning.local/schemas/review-bundle-config.schema.json",
  "title": "Review bundle configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "repository", "scope", "validations", "dependencies", "bundle"],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["expected_branch", "base_head", "require_changes", "require_empty_staging"],
      "properties": {
        "expected_branch": {"type": "string", "minLength": 1},
        "base_head": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "require_changes": {"type": "boolean"},
        "require_empty_staging": {"type": "boolean"}
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["paths", "enforce_exact"],
      "properties": {
        "paths": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "enforce_exact": {"type": "boolean"}
      }
    },
    "validations": {
      "type": "array",
      "items": {"$ref": "#/$defs/command"}
    },
    "dependencies": {
      "type": "array",
      "items": {"$ref": "#/$defs/command"}
    },
    "bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["root_directory"],
      "properties": {
        "root_directory": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"}
      }
    }
  },
  "$defs": {
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "argv", "cwd", "required", "timeout_seconds"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$"},
        "argv": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "cwd": {"type": "string", "minLength": 1},
        "required": {"type": "boolean"},
        "timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 3600}
      }
    }
  }
}
