{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://hugeplanning.local/governance/schemas/protocols/GOV-PROTOCOL-002/0.1.0/finding-closure-verdicts.schema.json",
  "type":"object","required":["finding_closure_verdicts"],"additionalProperties":false,
  "properties":{"finding_closure_verdicts":{"type":"object","required":["schema_version","run","protocol","original_findings","new_findings","regression_findings"],"properties":{"schema_version":{"const":"0.1.0"},"run":{"pattern":"^KGR-[0-9]{3}$"},"protocol":{"const":"GOV-PROTOCOL-002"},"original_findings":{"type":"array","minItems":15,"maxItems":15,"items":{"$ref":"#/$defs/original"}},"new_findings":{"type":"array","items":{"$ref":"#/$defs/new"}},"regression_findings":{"type":"array","items":{"$ref":"#/$defs/regression"}}},"additionalProperties":false}},
  "$defs":{
    "original":{"type":"object","required":["finding_id","original_severity","designer_disposition","adversary_verdict","evidence_refs","failed_criteria","reopen_event","residual_risk"],"properties":{"finding_id":{"pattern":"^KA-F-[0-9]{3}$"},"original_severity":{"enum":["CRITICAL","HIGH","MEDIUM","LOW","OBSERVATION"]},"designer_disposition":{"type":"string"},"adversary_verdict":{"enum":["CONFIRMED_CLOSED","REOPENED","ROUTED_CONFIRMED"]},"evidence_refs":{"type":"array"},"failed_criteria":{"type":"array","items":{"type":"string"}},"reopen_event":{"type":["object","null"]},"residual_risk":{"type":"string"}},"additionalProperties":false},
    "new":{"type":"object","required":["finding_id","type","severity","discovered_in_run","evidence_refs","relationships"],"properties":{"finding_id":{"pattern":"^KA-F-[0-9]{3}$"},"type":{"const":"NEW_FINDING"},"severity":{"enum":["CRITICAL","HIGH","MEDIUM","LOW","OBSERVATION"]},"discovered_in_run":{"pattern":"^KGR-[0-9]{3}$"},"evidence_refs":{"type":"array"},"relationships":{"type":"array"}},"additionalProperties":true},
    "regression":{"type":"object","required":["finding_id","type","severity","discovered_in_run","evidence_refs","relationships"],"properties":{"finding_id":{"pattern":"^KA-F-[0-9]{3}$"},"type":{"const":"REGRESSION"},"severity":{"enum":["CRITICAL","HIGH","MEDIUM","LOW","OBSERVATION"]},"discovered_in_run":{"pattern":"^KGR-[0-9]{3}$"},"evidence_refs":{"type":"array"},"relationships":{"type":"array","minItems":1,"contains":{"type":"object","properties":{"type":{"const":"REGRESSION_OF"}},"required":["type","finding_id"]}}},"additionalProperties":true}
  }
}
