  "type":"object","required":["designer_remediation_result"],"additionalProperties":false,
  "properties":{"designer_remediation_result":{"type":"object","required":["schema_version","run","protocol","loop","execution","designer_result","decision_matrix","counter_facts","controller","authority","exact_next_action"],"properties":{"schema_version":{"const":"0.1.0"},"run":{"pattern":"^KGR-[0-9]{3}$"},"protocol":{"const":"GOV-PROTOCOL-003"},"loop":{"type":"object","required":["id","version"],"properties":{"id":{"const":"GOV-LOOP-001"},"version":{"const":"0.1.0"}},"additionalProperties":false},"execution":{"type":"object","required":["package_validation","substantive_remediation_completed","valid_completed_run"],"properties":{"package_validation":{"const":"PASSED"},"substantive_remediation_completed":{"const":true},"valid_completed_run":{"const":true}},"additionalProperties":false},"designer_result":{"type":"object","required":["status","rationale_refs"],"properties":{"status":{"enum":["READY_FOR_TARGETED_CLOSURE","OWNER_DECISION_REQUIRED","RESEARCH_REQUIRED","STRUCTURAL_REDESIGN_REQUIRED"]},"rationale_refs":{"type":"array"}},"additionalProperties":false},"decision_matrix":{"type":"object","required":["version","evaluated_in_priority_order","selected_priority","selected_result","matched_conditions","higher_priority_conditions_confirmed_false"]},"counter_facts":{"type":"object"},"controller":{"type":"object","required":["final_transition","counters_after"],"properties":{"final_transition":{"const":"PENDING_CONTROLLER_VALIDATION"},"counters_after":{"const":"PENDING_CONTROLLER_VALIDATION"}},"additionalProperties":false},"authority":{"type":"object","required":["kernel_status","enforcement_engineering_gate","human_ratification"],"properties":{"kernel_status":{"const":"PROPOSED_NOT_RATIFIED"},"enforcement_engineering_gate":{"const":"CLOSED"},"human_ratification":{"const":"NOT_STARTED"}},"additionalProperties":true},"exact_next_action":{"type":"string"}},"additionalProperties":false}}
}
