{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Sugar144/HugePlanning/blob/v0.1.0/schemas/project.schema.json",
  "title": "Freelance methodology project state",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "project", "workflow", "tracking", "approvals", "privacy", "counters"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "client_display_name", "language", "archetype", "profile", "profile_history", "status", "repository_visibility"],
      "properties": {
        "id": {"type": "string", "pattern": "^[A-Z][A-Z0-9]*(?:-[A-Z0-9]+)*$"},
        "name": {"type": "string", "minLength": 1},
        "client_display_name": {"type": "string", "minLength": 1},
        "language": {"type": "string", "pattern": "^[a-z]{2}(?:-[A-Z]{2})?$"},
        "archetype": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"enum": ["static-landing", "corporate-content-site", "cms-content-site", "forms-or-lead-generation", "booking-system", "e-commerce", "authenticated-web-app", "integration-heavy-web-app", "migration-or-replatforming"]}
        },
        "profile": {"enum": ["lite", "standard", "high-risk"]},
        "profile_history": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/profile_history_entry"}
        },
        "status": {"enum": ["active", "paused", "archived"]},
        "repository_visibility": {"const": "private"}
      }
    },
    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["current_stage", "stage_status", "stages_done"],
      "properties": {
        "current_stage": {"$ref": "#/$defs/stage"},
        "stage_status": {"enum": ["not_started", "in_progress", "blocked", "in_review", "approved", "done"]},
        "stages_done": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/stage"}
        }
      }
    },
    "tracking": {
      "type": "object",
      "additionalProperties": false,
      "required": ["jira"],
      "properties": {
        "jira": {
          "oneOf": [
            {"enum": ["none", "default"]},
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["status", "reason"],
              "properties": {
                "status": {"const": "waived"},
                "reason": {"type": "string", "minLength": 1}
              }
            }
          ]
        }
      }
    },
    "approvals": {
      "type": "object",
      "additionalProperties": false,
      "required": ["g0_readiness", "g1_discovery_review", "g2_business_baseline", "g3_technical_baseline", "g4_task_ready", "g5_task_merge", "g6_staging_release", "g7_client_acceptance", "g8_production_release", "g9_change_approval"],
      "properties": {
        "g0_readiness": {"$ref": "#/$defs/nullable_approval"},
        "g1_discovery_review": {"$ref": "#/$defs/nullable_approval"},
        "g2_business_baseline": {"$ref": "#/$defs/nullable_approval"},
        "g3_technical_baseline": {"$ref": "#/$defs/nullable_approval"},
        "g4_task_ready": {"$ref": "#/$defs/nullable_approval"},
        "g5_task_merge": {"$ref": "#/$defs/nullable_approval"},
        "g6_staging_release": {"$ref": "#/$defs/nullable_approval"},
        "g7_client_acceptance": {"$ref": "#/$defs/nullable_approval"},
        "g8_production_release": {"$ref": "#/$defs/nullable_approval"},
        "g9_change_approval": {"$ref": "#/$defs/nullable_approval"}
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["data_sensitivity", "pii_in_evidence", "retention_after_close_months", "deletion_contact"],
      "properties": {
        "data_sensitivity": {"enum": ["low", "medium", "high"]},
        "pii_in_evidence": {"const": "minimized"},
        "retention_after_close_months": {"type": "integer", "minimum": 1},
        "deletion_contact": {"type": "string", "minLength": 3}
      }
    },
    "counters": {
      "type": "object",
      "additionalProperties": false,
      "required": ["OBJ", "FR", "NFR", "INT", "CON", "DAT", "CNT", "BR", "ASM", "OQ", "CLAR", "CTR", "EP", "US", "UC", "TASK", "BUG", "CR", "ADR", "SPK", "RSK", "TEST", "REL", "INC"],
      "properties": {
        "OBJ": {"$ref": "#/$defs/counter"}, "FR": {"$ref": "#/$defs/counter"}, "NFR": {"$ref": "#/$defs/counter"},
        "INT": {"$ref": "#/$defs/counter"}, "CON": {"$ref": "#/$defs/counter"}, "DAT": {"$ref": "#/$defs/counter"},
        "CNT": {"$ref": "#/$defs/counter"}, "BR": {"$ref": "#/$defs/counter"}, "ASM": {"$ref": "#/$defs/counter"},
        "OQ": {"$ref": "#/$defs/counter"}, "CLAR": {"$ref": "#/$defs/counter"}, "CTR": {"$ref": "#/$defs/counter"},
        "EP": {"$ref": "#/$defs/counter"}, "US": {"$ref": "#/$defs/counter"}, "UC": {"$ref": "#/$defs/counter"},
        "TASK": {"$ref": "#/$defs/counter"}, "BUG": {"$ref": "#/$defs/counter"}, "CR": {"$ref": "#/$defs/counter"},
        "ADR": {"$ref": "#/$defs/counter"}, "SPK": {"$ref": "#/$defs/counter"}, "RSK": {"$ref": "#/$defs/counter"},
        "TEST": {"$ref": "#/$defs/counter"}, "REL": {"$ref": "#/$defs/counter"}, "INC": {"$ref": "#/$defs/counter"}
      }
    }
  },
  "$defs": {
    "stage": {"enum": ["onboarding", "discovery", "specification", "technical_design", "planning", "implementation", "validation", "release", "operation"]},
    "gate": {"type": "string", "pattern": "^G[0-9]$"},
    "counter": {"type": "integer", "minimum": 1},
    "profile_history_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "at", "gate", "by", "reason"],
      "properties": {
        "value": {"enum": ["lite", "standard", "high-risk"]},
        "at": {"type": "string", "format": "date"},
        "gate": {"$ref": "#/$defs/gate"},
        "by": {"type": "string", "minLength": 1},
        "reason": {"type": "string", "minLength": 1}
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["date", "by", "record"],
      "properties": {
        "date": {"type": "string", "format": "date"},
        "by": {"type": "string", "minLength": 1},
        "record": {"type": "string", "pattern": "^docs/handoffs/G[0-9]-[^/]+-[0-9]{2}\\.yaml$"}
      }
    },
    "nullable_approval": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/approval"}]}
  }
}
