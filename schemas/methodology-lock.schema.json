{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://freelance-methodology.invalid/schemas/methodology-lock/1.0.0/methodology-lock.schema.json",
  "title": "methodology.lock.yaml — methodology version pin (02 §7)",
  "description": "Pins the methodology version/commit, the Claude Code CLI version last smoke-checked (R-CC3), and the schema versions in force for this client project. Schema version 1.0.0 (S0a).",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "methodology", "schemas"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "methodology": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "version", "commit", "applied_at", "claude_code_version"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "commit": { "type": "string", "pattern": "^[0-9a-f]{7,40}$" },
        "applied_at": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
        "claude_code_version": { "type": "string", "minLength": 1 }
      }
    },
    "schemas": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "patternProperties": {
        "^[a-z][a-z0-9-]*$": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" }
      }
    }
  }
}
